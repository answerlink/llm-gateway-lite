version: 1

providers:
  openai:
    type: openai_compat
    base_url: "https://api.openai.com"
    endpoints:
      chat_completions: "/v1/chat/completions"
      embeddings: "/v1/embeddings"
    auth:
      mode: "bearer"
      header: "Authorization"
      prefix: "Bearer "
    keys:
      # 方式1: 直接配置密钥值（推荐，更简单）
      - id: "openai-key-1"
        value: "sk-your-api-key-here"
      # 方式2: 从环境变量读取（兼容旧方式）
      # - id: "openai-key-2"
      #   value_env: "OPENAI_API_KEY_1"
    weight: 5
    timeout_ms: 60000
    ssl_verify: true

  openrouter:
    type: openai_compat
    base_url: "https://openrouter.ai"
    endpoints:
      chat_completions: "/api/v1/chat/completions"
    auth:
      mode: "bearer"
      header: "Authorization"
      prefix: "Bearer "
    headers:
      "HTTP-Referer": "https://your.app"
      "X-Title": "llm-gateway-lite"
    keys:
      # 支持直接配置 value 或从环境变量读取 value_env
      - id: "or-key-1"
        value: "sk-or-v1-your-key-here"
      # 或者使用环境变量:
      # - id: "or-key-2"
      #   value_env: "OPENROUTER_API_KEY"
    weight: 2
    timeout_ms: 90000

  primary-provider:
    type: openai_compat
    base_url: "https://openrouter.ai"
    endpoints:
      chat_completions: "/api/v1/chat/completions"
    auth:
      mode: "bearer"
      header: "Authorization"
      prefix: "Bearer "
    headers:
      "HTTP-Referer": "https://your.app"
      "X-Title": "llm-gateway-lite"
    keys:
      - id: "primary-provider-key-1"
        value: "sk-or-v1-your-key-here"
    weight: 6
    timeout_ms: 90000

  gemini:
    type: openai_compat
    base_url: "https://generativelanguage.googleapis.com"
    endpoints:
      chat_completions: "/v1beta/openai/chat/completions"
    auth:
      mode: "bearer"
      header: "Authorization"
      prefix: "Bearer "
    keys:
      # 两种方式都支持：value 或 value_env
      - id: "gemini-key-1"
        value: "your-gemini-api-key"
      # - id: "gemini-key-2"
      #   value_env: "GEMINI_API_KEY"
    weight: 3
    timeout_ms: 60000
